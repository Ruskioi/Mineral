{
  "name": "simba-ai-excel",
  "version": "1.0.0",
  "description": "Simba AI — an AI assistant sidebar for Microsoft Excel, powered by Claude.",
  "type": "module",
  "scripts": {
    "dev-certs": "office-addin-dev-certs install",
    "start": "concurrently -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "webpack serve --mode development",
    "dev:api": "node server/server.js",
    "backend": "node server/server.js",
    "build": "webpack --mode production",
    "start:prod": "npm run build && node server/server.js",
    "manifest": "node scripts/make-manifest.mjs",
    "manifest:prod": "node scripts/make-manifest.mjs --new-id --out manifest.prod.xml",
    "sideload": "office-addin-debugging start manifest.xml",
    "validate": "office-addin-manifest validate manifest.xml",
    "test": "node test/unit.mjs",
    "check": "npm run test && npm run build"
  },
  "author": "Simba AI",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "jose": "^6.2.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^6.0.0",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^2.0.0",
    "style-loader": "^3.3.4",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.2"
  }
}
