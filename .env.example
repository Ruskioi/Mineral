# Copy this file to ".env" and fill in your key. Never commit the real .env.

# Your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# Claude model the backend uses for real work (defaults to claude-opus-4-8)
SIMBA_MODEL=claude-opus-4-8
# Cheaper/faster model used for simple, conversational questions (auto-routed).
# SIMBA_MODEL_SIMPLE=claude-haiku-4-5-20251001
# Set to 0 to disable the automatic model router (always use SIMBA_MODEL).
# SIMBA_ROUTER=1
# Experimental: remote MCP connectors (admin-configured). JSON array; when set,
# the model can use those servers' tools. Off by default.
# SIMBA_MCP_SERVERS=[{"name":"notion","url":"https://mcp.notion.com/mcp","token":"..."}]
# Port the Simba backend listens on (the web dev server proxies /api here)
PORT=3001
# Default answer speed: fast | balanced | thorough
SIMBA_SPEED=balanced
# Per-IP request cap for /api/chat per minute (denial-of-wallet protection)
SIMBA_IP_RPM=15
# Optional per-user daily turn cap (0 = off). Needs SSO; keyed to the Microsoft
# identity. A simple org cost guard. Example: SIMBA_USER_DAILY=300
# SIMBA_USER_DAILY=0
# CORS allowlist (comma-separated). Leave empty for single-origin hosting (no CORS).
SIMBA_ALLOWED_ORIGINS=
# Require Microsoft sign-in for ALL model endpoints (chat/document/analyze/code/
# research). Strongly recommended once SSO works — otherwise anyone who finds the
# URL can drive Claude calls on your bill. Needs AAD_CLIENT_ID configured.
# SIMBA_REQUIRE_AUTH=1
# Timezone used to bucket usage stats + daily quotas (default Europe/Stockholm).
# SIMBA_TZ=Europe/Stockholm
# Max Postgres connections for the shared pool (default 10).
# SIMBA_PG_POOL=10
# Microsoft Teams bot (optional): Azure Bot app id + secret. Messaging endpoint
# is https://DIN_HOST/api/teams/messages — see docs/SSO-SETUP.md.
# TEAMS_APP_ID=
# TEAMS_APP_PASSWORD=
# Vault auto-ingest: how often synced SharePoint/OneDrive folders re-sync (min).
# Needs the APPLICATION Graph permission Files.Read.All + SIMBA_SCHEDULER=1.
# SIMBA_INGEST_INTERVAL_MIN=60
# Browser agent (browse_website): lets Simba drive a real headless Chromium via
# computer use. Requires `npm install playwright` (+ its browsers) on the server.
# Off by default — it's the most powerful tool; enable deliberately.
# SIMBA_BROWSER=1
# Governance view (/api/org-usage): who may see the org-wide usage dashboard
# (comma-separated Microsoft object-ids). Falls back to SIMBA_VAULT_ADMINS;
# empty = any signed-in org member.
# SIMBA_ADMINS=
# Optional org-wide daily spend cap (estimated USD across ALL users). When the
# day's estimated cost reaches this, chat answers 429 until local midnight.
# SIMBA_ORG_DAILY_USD=50

# --- Microsoft 365 sign-in + cross-device memory (optional) ---
# Azure AD app (client) id. Set this to enable SSO; the same id must go in the
# manifest: npm run manifest -- --base <host> --aad <AAD_CLIENT_ID> --new-id --out manifest.prod.xml
AAD_CLIENT_ID=
# Optional: pin SSO to a single Entra tenant GUID (reject all other tenants).
AAD_TENANT=
# Client secret for OneDrive/SharePoint access (Microsoft Graph on-behalf-of).
# Also grant the Azure app the DELEGATED Graph permission Files.Read.
AAD_CLIENT_SECRET=
# Managed Postgres connection string (Neon/Supabase/Render). Without it, memory,
# conversations, jobs and the knowledge vault are in-process only (wiped on
# restart). Required for durable cross-device memory and the shared company vault.
DATABASE_URL=
# Knowledge vault (Simba's shared org-wide "mind"): by default any signed-in org
# member can add/edit entries. To restrict WRITES to specific people, list their
# Microsoft object-ids (oids), comma-separated. Reading is always allowed in-org.
# SIMBA_VAULT_ADMINS=
# Semantic (vector) search for the vault — set a Voyage AI key to enable; without
# it the vault falls back to keyword search. With a key, entries are also split
# into passage-level chunks and a cross-encoder reranks results for precision.
# Optional model overrides too.
# VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3.5
# VOYAGE_RERANK_MODEL=rerank-2.5
# Finance / business-system connectors (Fortnox, Visma, project tools, any REST
# API): configured in the app by an admin (🔌 Datakällor) — base URL + secret
# auth headers (kept server-side) + whitelisted read endpoints. Who may add/edit
# them is gated by SIMBA_VAULT_ADMINS (the org admins); reading data is in-org.
# Recommended: paste your Postgres provider's CA bundle (PEM) to validate the
# server cert. Without it, TLS is used but the cert is not verified.
PGSSL_CA=
# Set to 1 only if your Postgres does NOT use TLS (most managed providers do).
# PGSSL_DISABLE=

# --- Scheduled server-side agent (optional) ---
# Lets Simba run recurring jobs that edit a OneDrive/SharePoint workbook on a
# schedule even when Excel is closed (e.g. "every Monday refresh the dashboard").
# Turn it on by setting this to 1. Requires DATABASE_URL (durable jobs) and the
# app-only Graph permission below. Enable on ONE instance only (or jobs run twice).
# SIMBA_SCHEDULER=1
# How often the scheduler checks for due jobs, in ms (default 60000).
# SIMBA_SCHEDULER_TICK_MS=60000
# Unattended runs act as the app itself, so in Azure also grant the APPLICATION
# Graph permission Files.ReadWrite.All (with admin consent) in addition to the
# delegated Files.Read above. AAD_TENANT must be a concrete tenant GUID (not
# "common") for app-only token requests to work.
