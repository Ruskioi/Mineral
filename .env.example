# Copy this file to ".env" and fill in your key. Never commit the real .env.

# Your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# Claude model the backend uses (defaults to claude-opus-4-8)
SIMBA_MODEL=claude-opus-4-8
# Port the Simba backend listens on (the web dev server proxies /api here)
PORT=3001
# Default answer speed: fast | balanced | thorough
SIMBA_SPEED=balanced
# Per-IP request cap for /api/chat per minute (denial-of-wallet protection)
SIMBA_IP_RPM=15
# CORS allowlist (comma-separated). Leave empty for single-origin hosting (no CORS).
SIMBA_ALLOWED_ORIGINS=

# --- Microsoft 365 sign-in + cross-device memory (optional) ---
# Azure AD app (client) id. Set this to enable SSO; the same id must go in the
# manifest: npm run manifest -- --base <host> --aad <AAD_CLIENT_ID> --new-id --out manifest.prod.xml
AAD_CLIENT_ID=
# Optional: pin SSO to a single Entra tenant GUID (reject all other tenants).
AAD_TENANT=
# Client secret for OneDrive/SharePoint access (Microsoft Graph on-behalf-of).
# Also grant the Azure app the DELEGATED Graph permission Files.Read.
AAD_CLIENT_SECRET=
# Managed Postgres connection string (Neon/Supabase/Render). Without it, memory
# is in-process only (wiped on restart). Required for durable cross-device memory.
DATABASE_URL=
# Recommended: paste your Postgres provider's CA bundle (PEM) to validate the
# server cert. Without it, TLS is used but the cert is not verified.
PGSSL_CA=
# Set to 1 only if your Postgres does NOT use TLS (most managed providers do).
# PGSSL_DISABLE=

# --- Scheduled server-side agent (optional) ---
# Lets Simba run recurring jobs that edit a OneDrive/SharePoint workbook on a
# schedule even when Excel is closed (e.g. "every Monday refresh the dashboard").
# Turn it on by setting this to 1. Requires DATABASE_URL (durable jobs) and the
# app-only Graph permission below. Enable on ONE instance only (or jobs run twice).
# SIMBA_SCHEDULER=1
# How often the scheduler checks for due jobs, in ms (default 60000).
# SIMBA_SCHEDULER_TICK_MS=60000
# Unattended runs act as the app itself, so in Azure also grant the APPLICATION
# Graph permission Files.ReadWrite.All (with admin consent) in addition to the
# delegated Files.Read above. AAD_TENANT must be a concrete tenant GUID (not
# "common") for app-only token requests to work.
